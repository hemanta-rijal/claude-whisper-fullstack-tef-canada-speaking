# Copy to `backend/.env` (gitignored) for local development.
# Never commit real secrets to git.

NODE_ENV=development
PORT=3000

# MySQL connection string for Prisma.
# Example for local MySQL (matches `backend/docker-compose.yml` if you use Docker for MySQL):
# mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME
#
# If your password has special characters, URL-encode them in the connection string.
DATABASE_URL=mysql://app:app@127.0.0.1:3306/app

# Non-DB API keys (examples)
# OPENAI_API_KEY=...
EXAMPLE_API_KEY=replace_me

# Local-only user seeding (used by `scripts/seed-one-user.ts`)
# `SEED_DEV_PASSWORD` is NEVER stored in git; it gets hashed into `User.passwordHash`.
SEED_DEV_EMAIL=dev@local.test
SEED_DEV_PASSWORD=Admin123!
