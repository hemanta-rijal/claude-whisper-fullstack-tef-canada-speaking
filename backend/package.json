{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json && cp -R src/assets dist/src/assets",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:ping": "echo \"SELECT 1;\" | prisma db execute --stdin --schema prisma/schema.prisma",
    "seed:dev-user": "tsx scripts/seed-one-user.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
