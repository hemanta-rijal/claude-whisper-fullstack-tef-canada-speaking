
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  imageUrl  String?
  passwordHash String?
  email            String?   @unique
  emailVerifiedAt  DateTime?
  oauthProvider             AuthProvider?
  oauthProviderAccountId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([oauthProvider, oauthProviderAccountId])
  @@index([oauthProviderAccountId])

  // One user can have many active sessions (one per device/browser).
  sessions Session[]
}

model Session {
  id     String @id @default(cuid())
  userId String
  // Prisma relation: `Session.userId` references `User.id`
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  expiresAt  DateTime?
  revokedAt  DateTime?
  lastSeenAt DateTime?
  ip         String?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
}

enum AuthProvider {
  GOOGLE
  GITHUB
}
